<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
    <interface>
        <function name="handleDeepLink" />
    </interface>

    <script type="text/brightscript" uri="MainScene.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/config.brs" />

    <children>
        <!-- Guide screen -->
        <Rectangle
            id="guidePanel"
            width="1280"
            height="720"
            color="#0D1117"
        >
            <!-- Header row -->
            <Label
                id="titleLabel"
                text="Lineup"
                translation="[60, 22]"
                font="font:LargeBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                id="dateLabel"
                translation="[1020, 30]"
                font="font:SmallSystemFont"
                color="#8B95A5"
                horizAlign="right"
                width="220"
            />

            <!-- Sport filter pills -->
            <Group id="sportPillsGroup" translation="[60, 70]" />

            <!-- Events scroll area -->
            <Group id="eventsGroup" translation="[60, 120]" />

            <!-- Loading -->
            <Label
                id="loadingLabel"
                text="Loading sports..."
                translation="[0, 380]"
                width="1280"
                horizAlign="center"
                font="font:MediumSystemFont"
                color="#8B95A5"
                visible="true"
            />

            <!-- Empty -->
            <Label
                id="emptyLabel"
                text="No live or upcoming events"
                translation="[0, 380]"
                width="1280"
                horizAlign="center"
                font="font:MediumSystemFont"
                color="#8B95A5"
                visible="false"
            />
        </Rectangle>

        <!-- Settings screen -->
        <Rectangle
            id="settingsPanel"
            width="1280"
            height="720"
            color="#0D1117"
            visible="false"
        >
            <Label
                text="Lineup"
                translation="[60, 22]"
                font="font:LargeBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                text="Streaming Services"
                translation="[60, 75]"
                font="font:MediumBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                text="Press OK to toggle. Press Back to return to Guide."
                translation="[60, 108]"
                font="font:SmallSystemFont"
                color="#8B95A5"
            />
            <Group id="serviceListGroup" translation="[60, 150]" />
        </Rectangle>

        <!-- Service picker overlay -->
        <Rectangle
            id="pickerOverlay"
            width="1280"
            height="720"
            color="#000000CC"
            visible="false"
        >
            <Rectangle
                id="pickerBox"
                width="460"
                height="300"
                color="#1A1F2E"
                translation="[410, 210]"
            >
                <Label
                    id="pickerTitle"
                    text="Available on"
                    translation="[20, 20]"
                    width="420"
                    horizAlign="center"
                    font="font:MediumBoldSystemFont"
                    color="#FFFFFF"
                />
                <Label
                    id="pickerSubtitle"
                    translation="[20, 52]"
                    width="420"
                    horizAlign="center"
                    font="font:SmallSystemFont"
                    color="#8B95A5"
                />
                <Group id="pickerItemsGroup" translation="[40, 90]" />
            </Rectangle>
        </Rectangle>

        <EventFetchTask id="fetchTask" />
    </children>
</component>
