{
  "cli": {
    "version": ">= 3.15.1"
  },
  "build": {
    "development": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "withoutCredentials": true,
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      }
    },
    "development_tv": {
      "extends": "development",
      "env": {
        "EXPO_TV": "1"
      }
    },
    "preview": {
      "extends": "production",
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      }
    },
    "preview_tv": {
      "extends": "preview",
      "env": {
        "EXPO_TV": "1"
      }
    },
    "production": {},
    "production_tv": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_TV": "1"
      }
    },
    "production_tv_apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_TV": "1"
      }
    },
    "production_tv_ios": {
      "extends": "production",
      "ios": {
        "simulator": false,
        "scheme": "Lineup"
      },
      "env": {
        "EXPO_TV": "1",
        "EXPO_USE_PRECOMPILED_MODULES": "0",
        "LINEUP_DEBUG_TVOS_INFOPLIST": "1"
      }
    },
    "preview_tv_ios": {
      "extends": "production_tv_ios",
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    }
  },
  "submit": {
    "production": {},
    "production_tv_ios": {
      "ios": {
        "ascAppId": "6762933531"
      }
    }
  }
}
